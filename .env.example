# ──────────────────────────────────────────────────────────────
# .env.example — Sistem NFC Peken Banyumasan (FastAPI)
# Salin file ini ke .env dan isi nilainya sebelum menjalankan.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key (JANGAN expose ke frontend/publik)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Integrasi API Eksternal UMKM ──────────────────────────────
UMKM_API_BASE_URL=https://jauharfz-umkm-serverside.hf.space
UMKM_API_KEY=
UMKM_ADMIN_SECRET_KEY=
# true = data mock (dev/staging), false = live API
UMKM_USE_MOCK=true

# ── Member Lookup (shared secret Gate ↔ UMKM) ─────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MEMBER_LOOKUP_API_KEY=

# ── App ───────────────────────────────────────────────────────
APP_DEBUG=false
PORT=8000
