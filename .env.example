# ──────────────────────────────────────────────────────────────
# .env.example — Sistem NFC Peken Banyumasan (Flask API)
# Salin file ini ke .env dan isi nilainya sebelum menjalankan.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.c

# Service Role Key: Supabase Dashboard → Settings → API → service_role (secret)
# JANGAN expose key ini ke frontend / publik.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Integrasi API Eksternal Kelompok UMKM ─────────────────────
# URL endpoint API eksternal kelompok UMKM (REQ-INTEG-001)
UMKM_API_URL=https://api-umkm-kelompok.example.com/tenants

# Bearer token untuk API eksternal (kosongkan jika tidak ada auth)
UMKM_API_KEY=

# ── Flask ─────────────────────────────────────────────────────
# false untuk production, true untuk development
FLASK_DEBUG=false

# Port yang digunakan (Railway/Render akan inject ini otomatis)
PORT=5000
